# Hugo Admin Docker 部署配置
# 复制此文件为 .env 并根据实际情况修改

# Hugo 博客目录（默认为 ../hugo-blog）
HUGO_BLOG_DIR=../hugo-blog

# Hugo 主题目录（默认为 ../Fried-Rice）
HUGO_THEME_DIR=../Fried-Rice

# Flask 密钥（生产环境必须修改）
SECRET_KEY=dev-secret-key-change-in-production

# 管理员账户（首次启动时写入 data/auth.json，之后可在应用内修改密码）
# 注意：未设置这两个环境变量时，应用会以 admin/admin 引导默认账户（仅限本地，务必尽快改密）。
# 生产部署请务必在此设置强用户名/密码（下方为占位示例）。
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me-strong-password

# Hugo 预览服务器地址
HUGO_SERVER_BASE_URL=http://localhost:1313
